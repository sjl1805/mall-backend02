<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.mapper.UsersMapper">

    <resultMap id="BaseResultMap" type="com.example.model.entity.Users">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="username" column="username" jdbcType="VARCHAR"/>
        <result property="password" column="password" jdbcType="VARCHAR"/>
        <result property="nickname" column="nickname" jdbcType="VARCHAR"/>
        <result property="phone" column="phone" jdbcType="VARCHAR"/>
        <result property="email" column="email" jdbcType="VARCHAR"/>
        <result property="avatar" column="avatar" jdbcType="VARCHAR"/>
        <result property="gender" column="gender" jdbcType="TINYINT"/>
        <result property="status" column="status" jdbcType="TINYINT"/>
        <result property="role" column="role" jdbcType="TINYINT"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
        <result property="createDate" column="create_date" jdbcType="DATE"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, username, password, nickname, phone, email, 
        avatar, gender, status, role, create_time, update_time
    </sql>

    <!-- 增强分页查询，添加注释说明每个条件 -->
    <select id="selectUserPage" resultType="com.example.model.entity.Users">
        <!-- 使用include标签复用字段列表 -->
        SELECT
        <include refid="Base_Column_List"/>
        FROM users
        <where>
            <!-- 用户名模糊查询 -->
            <if test="query.username != null and query.username != ''">
                AND username LIKE CONCAT('%', #{query.username}, '%')
            </if>
            <!-- 精确手机号查询 -->
            <if test="query.phone != null and query.phone != ''">
                AND phone = #{query.phone}
            </if>
            <!-- 状态过滤 -->
            <if test="query.status != null">
                AND status = #{query.status}
            </if>
        </where>
        <!-- 动态排序实现 -->
        ORDER BY
        <choose>
            <when test="query.sortField == 'createTime'">
                create_time ${query.sortOrder}
            </when>
            <otherwise>
                create_time DESC
            </otherwise>
        </choose>
    </select>

    <!-- 根据手机号查询 -->
    <select id="selectByPhone" resultType="com.example.model.entity.Users">
        SELECT
        <include refid="Base_Column_List"/>
        FROM users
        WHERE phone = #{phone}
    </select>

    <!-- 统计用户状态 -->
    <select id="countUserStatus" resultType="map">
        SELECT status   AS status,
               COUNT(*) AS count
        FROM users
        GROUP BY status
    </select>

    <!-- 登录查询 -->
    <select id="selectByUsernameOrPhone" resultMap="BaseResultMap">
        SELECT *
        FROM users
        WHERE (username = #{account} OR phone = #{account})
          AND status = 1
        LIMIT 1
    </select>

    <!-- 更新用户状态 -->
    <update id="updateUserStatus">
        UPDATE users
        SET status      = #{status},
            update_time = NOW()
        WHERE id = #{userId}
    </update>

    <!-- 检查字段唯一性 -->
    <select id="checkFieldUnique" resultType="int">
        SELECT COUNT(*)
        FROM users
        WHERE ${field} = #{value}
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>
</mapper>
